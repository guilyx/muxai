# muxai runtime defaults
MUXAI_DEFAULT_PROVIDER=cursor
MUXAI_TIMEOUT_SECONDS=30
MUXAI_MAX_RETRIES=2

# Optional OpenAI-compatible base URL (useful for local model gateways)
# Example: http://localhost:11434/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Provider credentials
CURSOR_API_KEY=
CLAUDE_API_KEY=
VIBE_API_KEY=
